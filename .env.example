# ══════════════════════════════════════════════════════════════
# Portfolio Admin - Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Database (Vercel Postgres / Neon) ─────────────────────────
# Auto-set when you add the Vercel Postgres integration
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# ── Authentication ────────────────────────────────────────────
# Generate a random 32+ char string for JWT signing
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Storage Provider ──────────────────────────────────────────
# "blob" for Vercel Blob (default), "s3" for AWS S3 + CloudFront
STORAGE_PROVIDER=blob

# ── Vercel Blob ───────────────────────────────────────────────
# Auto-set when you add the Vercel Blob integration
BLOB_READ_WRITE_TOKEN=

# ── AWS S3 + CloudFront (fallback storage) ───────────────────
# Only needed if STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: CloudFront distribution domain for fast CDN delivery
CLOUDFRONT_DOMAIN=

# ── Deployment Tokens ─────────────────────────────────────────
# Netlify personal access token (for deploying to Netlify)
NETLIFY_TOKEN=

# Vercel token + project ID (for deploying to Vercel)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# ── Admin Credentials ─────────────────────────────────────────
# Used for initial admin account setup (run /api/setup or setup script)
ADMIN_EMAIL=malanaprincejeremie@gmail.com
ADMIN_PASSWORD=changeme123
