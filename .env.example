# Required - Vercel Postgres (auto-set when you add the integration)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Required - JWT secret (generate a random 32+ char string)
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Storage: "blob" for Vercel Blob, "s3" for AWS S3
STORAGE_PROVIDER=blob

# Vercel Blob (auto-set when you add the integration)
BLOB_READ_WRITE_TOKEN=

# AWS S3 (only needed if STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=

# Netlify deploy token (optional)
NETLIFY_TOKEN=

# Vercel deploy token (optional)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# Admin credentials for initial setup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
